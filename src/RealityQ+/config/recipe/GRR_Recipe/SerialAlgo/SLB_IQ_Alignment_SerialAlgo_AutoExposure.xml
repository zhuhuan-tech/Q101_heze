<?xml version="1.0"?>
<root main_tree_to_execute="BehaviorTree">
 <BehaviorTree ID="BehaviorTree">
  <!-- Add nodes here -->
  <Sequence name="Sequence">
   <!-- System Init -->
   <!-- <Action name="System_Tips" ID="System_Tips" tip="Please confirm whether the prism is in the SLB test state?"/> -->
   <Action name="System_Date" ID="System_Date" date_key="cur_data"/>
   <Action name="System_DateTime" ID="System_DateTime" date_time_key="cur_datatime"/>
   <!-- Devices Connect & CalibrationData Load -->
   <Parallel name="Parallel">
    <Action name="AA_Connect_MeasureCameraMotionModule" ID="AA_Connect_MeasureCameraMotionModule"/>
    <Action name="AA_Connect_ProjectorMotionModule" ID="AA_Connect_ProjectorMotionModule"/>
    <Action name="AA_Connect_DutMotionModule" ID="AA_Connect_DutMotionModule"/>
    <Action name="Reticle_2D_Connect" ID="Reticle_2D_Connect"/>
   </Parallel>
   <Action name="Colorimeter_Connect_All_Async" ID="Colorimeter_Connect_All_Async"/>
   <!-- SLB Alignment Module -->
   <Action name="IQ_SetDutID" ID="IQ_SetDutID" id_key="dutid" id_value="SLB"/>
   <Action name="IQ_SetTestState" ID="IQ_SetTestState" is_dut="0" is_update_slb="1" size="1" size_key="size"/>
   <Action name="AA_SetMotionMoveSpeed" ID="AA_SetMotionMoveSpeed" projector_dxdy="" dut_x="20" dut_y="20" dut_z="10" imaging_x="20" imaging_y="20" imaging_z="10" imaging_dxdy="" reticle_x="" reticle_y=""/>
   <IfThenElse name="IfThenElse">
    <Action name="System_CompareStr" ID="System_CompareStr" origin_str="{size}" target_str="Small"/>
    <Action name="SetBlackboard" ID="SetBlackboard" output_key="aperture" value="3"/>
    <Action name="SetBlackboard" ID="SetBlackboard" output_key="aperture" value="2.6"/>
   </IfThenElse>
   <Parallel name="Parallel">
    <Action name="AA_SLB_Alignment" ID="AA_SLB_Alignment"/>
    <Action name="IS_Connect" ID="IS_Connect"/>
    <Action name="AA_Connect_Polarizer" ID="AA_Connect_Polarizer"/>
    <Action name="Colorimeter_LoadCalibrationData" ID="Colorimeter_LoadCalibrationData" aperture="{aperture}" binning="1" colorfilter_list="X,Y,Z,Clear" ndfliter_list="ND3" lightsource_list="R,G,B" is_load_dark="1" is_load_colorshift="1" is_load_ffc="1" is_load_distortion="1" is_load_exposure="1" is_load_fliprotation="1" is_load_luminance="1" is_load_fourcolor="0"/>
    <Action name="Reticle_2D_Change" ID="Reticle_2D_Change" type="{size}" reticle_name="Clear"/>
   </Parallel>
   <!-- IQ Init -->
   <Action name="Polarizer_MoveAbs" ID="Polarizer_MoveAbs" position="136.625"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="ISphere_scale_R" value="0.96"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="ISphere_scale_G" value="0.96"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="ISphere_scale_B" value="0.96"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="ISphere_off" value="0,0,0"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="nd_select" value="ND3"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="xyzc_select" value="Clear"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="is_auto_exposure" value="1"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="exposure_init_time" value="1000"/>
   <Action name="SetBlackboard" ID="SetBlackboard" output_key="binning" value="4"/>
   <Action name="IQ_UpdateFlipRotation" ID="IQ_UpdateFlipRotation"/>
   <!-- IQ Metrics Module -->
   <Action name="IQ_SetEyeboxList" ID="IQ_SetEyeboxList" eyeboxlist="5" key="eyeboxids"/>
   <Action name="IQ_Metrics_CreateDBTable" ID="IQ_Metrics_CreateDBTable"/>
   <Action name="IQ_Metrics_CreateResultFile" ID="IQ_Metrics_CreateResultFile" all_csvname="SLB_metrics_all" csvname="SLB_metrics" dut_seq="{dutid}_{cur_datatime}" root_dir="E:\SAT_GRR\{cur_data}_MetricsTest"/>
   <Action name="Colorimeter_Camera_StopGrabbing" ID="Colorimeter_Camera_StopGrabbing"/>
   <IfThenElse name="IfThenElse">
    <Action name="System_CompareStr" ID="System_CompareStr" origin_str="{size}" target_str="Small"/>
    <Action name="Colorimeter_Motion_SetFocus" ID="Colorimeter_Motion_SetFocus" focus="28.701"/>
    <Action name="Colorimeter_Motion_SetFocus" ID="Colorimeter_Motion_SetFocus" focus="28.459"/>
   </IfThenElse>
   <Action name="Colorimeter_Camera_SetBinningSelector" ID="Colorimeter_Camera_SetBinningSelector" binning_selector="1"/>
   <Action name="Colorimeter_Camera_SetBinningMode" ID="Colorimeter_Camera_SetBinningMode" binning_mode="Average"/>
   <For name="For" traverse_params="{eyeboxids}">
    <Sequence name="Sequence">
     <Action name="System_GetForNodeValue1" ID="System_GetForNodeValue1" value_key="cur_eb"/>
     <For name="For" traverse_params="R,G,B;{ISphere_scale_R},{ISphere_scale_G},{ISphere_scale_B}">
      <Sequence name="Sequence">
       <Action name="System_GetForNodeValue2" ID="System_GetForNodeValue2" value_key1="color" value_key2="isphere_scale"/>
       <Action name="IS_SetSolution" ID="IS_SetSolution" isphere_scale="{isphere_scale}" light_source="{color}"/>
       <!-- Clear Pattern (R&G&B) -->
       <Action name="Reticle_2D_Change" ID="Reticle_2D_Change" type="{size}" reticle_name="Clear"/>
       <Action name="Colorimeter_Capture_LuminanceImage_Async" ID="Colorimeter_Capture_LuminanceImage_Async" aperture="3" dutid="{dutid}" eyeboxid="{cur_eb}" binning="{binning}" nd_filter="{nd_select}" color_filter="X" light_source="{color}" image_type="solid" is_set_et="1" is_auto_et="{is_auto_exposure}" exposure_time="{exposure_init_time}" is_convert_16bit="0" convert_method="0" save_raw_image="1" save_calibration_image="0" is_hdr="0" max_exposure_time=""/>
       <Action name="Colorimeter_Capture_LuminanceImage_Async" ID="Colorimeter_Capture_LuminanceImage_Async" aperture="3" dutid="{dutid}" eyeboxid="{cur_eb}" binning="{binning}" nd_filter="{nd_select}" color_filter="Y" light_source="{color}" image_type="solid" is_set_et="1" is_auto_et="{is_auto_exposure}" exposure_time="{exposure_init_time}" is_convert_16bit="0" convert_method="0" save_raw_image="1" save_calibration_image="0" is_hdr="0" max_exposure_time=""/>
       <IfThenElse name="IfThenElse">
        <Action name="System_CompareStr" ID="System_CompareStr" origin_str="{color}" target_str="R"/>
        <Action name="Colorimeter_Capture_LuminanceImage_Async" ID="Colorimeter_Capture_LuminanceImage_Async" aperture="3" dutid="{dutid}" eyeboxid="{cur_eb}" binning="{binning}" nd_filter="{nd_select}" color_filter="Z" light_source="{color}" image_type="solid" is_set_et="1" is_auto_et="0" exposure_time="1000" is_convert_16bit="0" convert_method="0" save_raw_image="1" save_calibration_image="0" is_hdr="0" max_exposure_time=""/>
        <Action name="Colorimeter_Capture_LuminanceImage_Async" ID="Colorimeter_Capture_LuminanceImage_Async" aperture="3" dutid="{dutid}" eyeboxid="{cur_eb}" binning="{binning}" nd_filter="{nd_select}" color_filter="Z" light_source="{color}" image_type="solid" is_set_et="1" is_auto_et="{is_auto_exposure}" exposure_time="{exposure_init_time}" is_convert_16bit="0" convert_method="0" save_raw_image="1" save_calibration_image="0" is_hdr="0" max_exposure_time=""/>
       </IfThenElse>
       <!-- Cross Pattern (R&G&B) -->
       <Action name="Reticle_2D_Change" ID="Reticle_2D_Change" type="{size}" reticle_name="Cross"/>
       <Action name="Colorimeter_Capture_GrayImage_Async" ID="Colorimeter_Capture_GrayImage_Async" aperture="3" dutid="{dutid}" eyeboxid="{cur_eb}" binning="1" nd_filter="{nd_select}" color_filter="{xyzc_select}" light_source="{color}" image_type="crosshair" is_set_et="1" is_auto_et="{is_auto_exposure}" exposure_time="{exposure_init_time}" is_convert_16bit="0" convert_method="0" save_raw_image="1" save_calibration_image="0" is_hdr="0" max_exposure_time=""/>
       <!-- PositiveChecker Pattern (R&G&B) -->
       <Action name="Reticle_2D_Change" ID="Reticle_2D_Change" type="{size}" reticle_name="PositiveChecker"/>
       <Action name="Colorimeter_Capture_GrayImage_Async" ID="Colorimeter_Capture_GrayImage_Async" aperture="3" dutid="{dutid}" eyeboxid="{cur_eb}" binning="{binning}" nd_filter="{nd_select}" color_filter="{xyzc_select}" light_source="{color}" image_type="checkerPositive" is_set_et="1" is_auto_et="{is_auto_exposure}" exposure_time="{exposure_init_time}" is_convert_16bit="0" convert_method="0" save_raw_image="1" save_calibration_image="0" is_hdr="0" max_exposure_time=""/>
       <!-- NegativeChecker Pattern (R&G&B) -->
       <Action name="Reticle_2D_Change" ID="Reticle_2D_Change" type="{size}" reticle_name="NegativeChecker"/>
       <Action name="Colorimeter_Capture_GrayImage_Async" ID="Colorimeter_Capture_GrayImage_Async" aperture="3" dutid="{dutid}" eyeboxid="{cur_eb}" binning="{binning}" nd_filter="{nd_select}" color_filter="{xyzc_select}" light_source="{color}" image_type="checkerNegative" is_set_et="1" is_auto_et="{is_auto_exposure}" exposure_time="{exposure_init_time}" is_convert_16bit="0" convert_method="0" save_raw_image="1" save_calibration_image="0" is_hdr="0" max_exposure_time=""/>
       <!-- Grid Pattern (R&G&B) -->
       <Action name="Reticle_2D_Change" ID="Reticle_2D_Change" type="{size}" reticle_name="Grid"/>
       <Action name="Colorimeter_Capture_GrayImage_Async" ID="Colorimeter_Capture_GrayImage_Async" aperture="3" dutid="{dutid}" eyeboxid="{cur_eb}" binning="1" nd_filter="{nd_select}" color_filter="{xyzc_select}" light_source="{color}" image_type="grid" is_set_et="1" is_auto_et="{is_auto_exposure}" exposure_time="{exposure_init_time}" is_convert_16bit="0" convert_method="0" save_raw_image="1" save_calibration_image="0" is_hdr="0" max_exposure_time=""/>
      </Sequence>
     </For>
    </Sequence>
   </For>
   <Parallel name="Parallel">
    <Action name="IS_SetSolution" ID="IS_SetSolution" isphere_scale="{ISphere_off}" light_source="W"/>
    <Sequence name="Sequence">
     <Action name="Colorimeter_WaitForCaptureEnd" ID="Colorimeter_WaitForCaptureEnd" timeout="20"/>
     <Action name="IQ_UpdateFixExposureTimeConfig" ID="IQ_UpdateFixExposureTimeConfig"/>
     <SequenceStar name="SequenceStar">
      <Action name="IQ_Metrics_Location_Clear" ID="IQ_Metrics_Location_Clear"/>
      <Parallel name="Parallel">
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="FOV"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="FOVOffset"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="Rotation"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="GridDistortion"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="CheckerContrast"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="GridDenseMTF"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="LuminanceEfficiency"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="LuminanceRolloff"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="LateralColor"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="Flare"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="PupilSwim"/>
       <Action name="IQ_Metrics_Calculate" ID="IQ_Metrics_Calculate" metrics_name="ColorUniformity"/>
      </Parallel>
      <Action name="IQ_Metrics_ExportToCSV" ID="IQ_Metrics_ExportToCSV"/>
     </SequenceStar>
    </Sequence>
    <Action name="AA_SLB_LoadSLB" ID="AA_SLB_LoadSLB"/>
   </Parallel>
  </Sequence>
 </BehaviorTree>
</root>
